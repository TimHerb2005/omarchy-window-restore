#!/usr/bin/env python3
# hypr-restore-settings: SUPER+CTRL+R
# Walker menu to configure Window Restore settings.

import json, os, subprocess

HISTORY_FILE = os.path.expanduser("~/.cache/hypr-window-history.json")
HIDDEN_FILE  = os.path.expanduser("~/.cache/hypr-restore-hidden.json")
MODE_FILE    = os.path.expanduser("~/.cache/hypr-restore-mode")
CONFIG_FILE  = os.path.expanduser("~/.cache/hypr-restore-config.json")

DEFAULT_EXCLUDED = ["org.omarchy.btop"]


def notify(color, msg, config=None):
    if config is None:
        config = get_config()
    if not config.get("notifications_enabled", True):
        return
    subprocess.run(["notify-send", "-t", "3000", "Window Restore", msg])


def get_mode():
    try:
        with open(MODE_FILE) as f: return f.read().strip()
    except: return "relaunch"


def set_mode(mode):
    os.makedirs(os.path.dirname(MODE_FILE), exist_ok=True)
    with open(MODE_FILE, "w") as f: f.write(mode)


def get_config():
    try:
        with open(CONFIG_FILE) as f: return json.load(f)
    except: return {"max_windows": 5, "excluded_classes": list(DEFAULT_EXCLUDED), "notifications_enabled": True}


def save_config(cfg):
    os.makedirs(os.path.dirname(CONFIG_FILE), exist_ok=True)
    with open(CONFIG_FILE, "w") as f: json.dump(cfg, f, indent=2)


def pick(items, placeholder):
    """Show a walker dmenu with predefined options."""
    result = subprocess.run(
        ["walker", "--dmenu", "--placeholder", placeholder],
        input="\n".join(items), capture_output=True, text=True
    )
    return result.stdout.strip()


def input_text(placeholder):
    """Show a walker freeform text input."""
    result = subprocess.run(
        ["walker", "--dmenu", "--inputonly", "--placeholder", placeholder],
        input="", capture_output=True, text=True
    )
    return result.stdout.strip()


def load_json(path):
    try:
        with open(path) as f: return json.load(f)
    except: return []


def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f: json.dump(data, f)


def trim_history(n):
    """Truncate relaunch history to n entries."""
    h = load_json(HISTORY_FILE)
    if len(h) > n:
        save_json(HISTORY_FILE, h[:n])


def trim_hidden(n):
    """Truncate hidden list to n entries, killing the excess windows."""
    hidden = load_json(HIDDEN_FILE)
    if len(hidden) > n:
        to_kill = hidden[n:]
        for entry in to_kill:
            addr = entry.get("address", "")
            if addr:
                subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{addr}"])
        save_json(HIDDEN_FILE, hidden[:n])


def kill_all_hidden():
    """Kill all processes currently hidden on workspace 99 and clear the hidden list."""
    hidden = load_json(HIDDEN_FILE)
    killed = 0
    for entry in hidden:
        addr = entry.get("address", "")
        if addr:
            subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{addr}"])
            killed += 1
    save_json(HIDDEN_FILE, [])
    return killed


def menu_mode(mode):
    new_mode = pick([
        "󰑓  Relaunch – app restarts fresh (default)" + ("  ✓" if mode == "relaunch" else ""),
        "󰈉  Hide – process stays alive, YouTube keeps playing" + ("  ✓" if mode == "hide" else ""),
    ], "Select mode")
    if not new_mode: return
    if "Relaunch" in new_mode and mode != "relaunch":
        # Kill all hidden windows before switching — their state can't be used in relaunch mode
        killed = kill_all_hidden()
        set_mode("relaunch")
        msg = f"󰑓  Mode: RELAUNCH  ({killed} hidden window{'s' if killed != 1 else ''} closed)" if killed else "󰑓  Mode: RELAUNCH"
        notify("8be9fd", msg)
    elif "Hide" in new_mode and mode != "hide":
        set_mode("hide")
        notify("bd93f9", "󰈉  Mode: HIDE – state is preserved")


def menu_max(config):
    max_w = config.get("max_windows", 5)
    raw = input_text(f"Max windows in history (current: {max_w})")
    if not raw:
        return
    try:
        n = int(raw)
        if n < 1:
            notify("ff5555", "  Invalid: value must be at least 1")
            return
        config["max_windows"] = n
        save_config(config)
        trim_history(n)
        trim_hidden(n)
        notify("50fa7b", f"  Max windows: {n}")
    except ValueError:
        notify("ff5555", f"  Invalid: '{raw}' is not a number")


def menu_exclusions(config):
    excluded = config.get("excluded_classes", [])

    action = pick([
        "  Enter app ID manually",
        "  Pick from open windows",
        f"  Remove entry  ({len(excluded)} in list)" if excluded else "  Remove entry  (list empty)",
    ], "Manage exclusion list")
    if not action: return

    if "manually" in action:
        app_id = input_text("Enter app class  (e.g. Alacritty, code, spotify)")
        if not app_id: return
        if app_id in excluded:
            notify("ff9900", f"  '{app_id}' is already excluded")
            return
        excluded.append(app_id)
        config["excluded_classes"] = excluded
        save_config(config)
        notify("ffb86c", f"  Excluded: {app_id}")

    elif "open" in action:
        try:
            r = subprocess.run(["hyprctl", "clients", "-j"], capture_output=True, text=True)
            clients = json.loads(r.stdout)
            classes = sorted(set(
                c["class"] for c in clients
                if c.get("class") and c["class"] not in excluded
            ))
        except:
            classes = []
        if not classes:
            notify("ff9900", "  No new apps open")
            return
        selected = pick(classes, "Select app to exclude")
        if not selected: return
        excluded.append(selected)
        config["excluded_classes"] = excluded
        save_config(config)
        notify("ffb86c", f"  Excluded: {selected}")

    elif "Remove" in action:
        if not excluded:
            notify("ff9900", "  Exclusion list is empty")
            return
        selected = pick(excluded, "Select entry to remove")
        if not selected: return
        excluded.remove(selected)
        config["excluded_classes"] = excluded
        save_config(config)
        notify("50fa7b", f"  Re-included: {selected}")


def menu_notify(config):
    enabled = config.get("notifications_enabled", True)
    new_val = pick([
        "  On – show notifications" + ("  ✓" if enabled else ""),
        "󰂛  Off – suppress all notifications" + ("  ✓" if not enabled else ""),
    ], "Notifications")
    if not new_val: return
    now_enabled = "On" in new_val
    config["notifications_enabled"] = now_enabled
    save_config(config)
    if now_enabled:
        notify("50fa7b", "  Notifications: ON", config)


def menu_pause(config):
    pause = config.get("pause_on_close", True)
    new_val = pick([
        "  On – pause media when closing/hiding a window" + ("  ✓" if pause else ""),
        "  Off – never pause media automatically" + ("  ✓" if not pause else ""),
    ], "Pause media on close")
    if not new_val: return
    enabled = "On" in new_val
    config["pause_on_close"] = enabled
    save_config(config)
    icon = "" if enabled else "󰝟"
    notify("50fa7b" if enabled else "ff9900", f"{icon}  Pause on close: {'ON' if enabled else 'OFF'}")


def menu_ws(config):
    ws = config.get("hide_workspace", 99)
    raw = input_text(f"Hide workspace number (current: {ws}, recommended: >= 50)")
    if not raw: return
    try:
        n = int(raw)
        if n < 1:
            notify("ff5555", "  Invalid: workspace must be >= 1")
            return
        if n < 10:
            notify("ff9900", f"  Warning: workspace {n} may conflict with your normal workspaces!")
            return
        old_ws = ws
        config["hide_workspace"] = n
        save_config(config)
        # Migrate any currently hidden windows from old workspace to new one
        hidden = load_json(HIDDEN_FILE)
        if hidden and old_ws != n:
            for entry in hidden:
                addr = entry.get("address", "")
                if addr:
                    subprocess.run(["hyprctl", "dispatch", "movetoworkspacesilent",
                                    f"{n},address:{addr}"], capture_output=True)
        notify("50fa7b", f"  Hide workspace: {n}")
    except ValueError:
        notify("ff5555", f"  Invalid: '{raw}' is not a number")


def main():
    mode   = get_mode()
    config = get_config()
    max_w  = config.get("max_windows", 5)
    excl   = config.get("excluded_classes", [])
    pause  = config.get("pause_on_close", True)
    hide_ws = config.get("hide_workspace", 99)

    mode_label  = "Hide" if mode == "hide" else "Relaunch"
    mode_icon   = "󰈉" if mode == "hide" else "󰑓"
    excl_count  = len(excl)
    pause_label = "On" if pause else "Off"
    notif_label = "On" if config.get("notifications_enabled", True) else "Off"

    menu = [
        f"{mode_icon}  Mode: {mode_label}  →  switch",
        f"  Max windows: {max_w}  →  enter number",
        f"  Exclusion list ({excl_count})  →  manage",
        f"  Pause media on close: {pause_label}  →  toggle",
        f"  Notifications: {notif_label}  →  toggle",
        f"  Hide workspace: {hide_ws}  →  enter number",
    ]

    selected = pick(menu, "Window Restore Settings")
    if not selected: return

    if "Mode" in selected:
        menu_mode(mode)
    elif "Max" in selected:
        menu_max(config)
    elif "Exclusion" in selected:
        menu_exclusions(config)
    elif "Pause" in selected:
        menu_pause(config)
    elif "Notifications" in selected:
        menu_notify(config)
    elif "workspace" in selected:
        menu_ws(config)


if __name__ == "__main__":
    main()
