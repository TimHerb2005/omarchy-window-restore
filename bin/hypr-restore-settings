#!/usr/bin/env python3
# hypr-restore-settings: SUPER+CTRL+R
# Walker menu to configure Window Restore settings.

import json, os, subprocess

HISTORY_FILE = os.path.expanduser("~/.cache/hypr-window-history.json")
HIDDEN_FILE  = os.path.expanduser("~/.cache/hypr-restore-hidden.json")
MODE_FILE   = os.path.expanduser("~/.cache/hypr-restore-mode")
CONFIG_FILE = os.path.expanduser("~/.cache/hypr-restore-config.json")


def notify(color, msg):
    subprocess.run(["hyprctl", "notify", "0", "3000", f"rgb({color})", msg])


def get_mode():
    try:
        with open(MODE_FILE) as f: return f.read().strip()
    except: return "relaunch"


def set_mode(mode):
    os.makedirs(os.path.dirname(MODE_FILE), exist_ok=True)
    with open(MODE_FILE, "w") as f: f.write(mode)


def get_config():
    try:
        with open(CONFIG_FILE) as f: return json.load(f)
    except: return {"max_windows": 5, "excluded_classes": []}


def save_config(cfg):
    os.makedirs(os.path.dirname(CONFIG_FILE), exist_ok=True)
    with open(CONFIG_FILE, "w") as f: json.dump(cfg, f, indent=2)


def pick(items, placeholder):
    """Show a walker dmenu with predefined options."""
    result = subprocess.run(
        ["walker", "--dmenu", "--placeholder", placeholder],
        input="\n".join(items), capture_output=True, text=True
    )
    return result.stdout.strip()


def input_text(placeholder):
    """Show a walker freeform text input."""
    result = subprocess.run(
        ["walker", "--dmenu", "--inputonly", "--placeholder", placeholder],
        input="", capture_output=True, text=True
    )
    return result.stdout.strip()


def load_json(path):
    try:
        with open(path) as f: return json.load(f)
    except: return []


def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f: json.dump(data, f)


def trim_history(n):
    """Truncate relaunch history to n entries."""
    h = load_json(HISTORY_FILE)
    if len(h) > n:
        save_json(HISTORY_FILE, h[:n])


def trim_hidden(n):
    """Truncate hidden list to n entries, killing the excess windows."""
    hidden = load_json(HIDDEN_FILE)
    if len(hidden) > n:
        to_kill = hidden[n:]
        for entry in to_kill:
            addr = entry.get("address", "")
            if addr:
                subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{addr}"])
        save_json(HIDDEN_FILE, hidden[:n])



    new_mode = pick([
        "󰑓  Relaunch – App startet neu (Standard)" + ("  ✓" if mode == "relaunch" else ""),
        "󰈉  Hide – Prozess bleibt, YouTube läuft weiter" + ("  ✓" if mode == "hide" else ""),
    ], "Modus wählen")
    if not new_mode: return
    if "Relaunch" in new_mode:
        set_mode("relaunch")
        notify("8be9fd", "󰑓  Modus: RELAUNCH")
    elif "Hide" in new_mode:
        set_mode("hide")
        notify("bd93f9", "󰈉  Modus: HIDE – Zustand bleibt erhalten")


def menu_max(config):
    max_w = config.get("max_windows", 5)
    raw = input_text(f"Max. Fenster in History (aktuell: {max_w})")
    if not raw:
        return
    try:
        n = int(raw)
        if n < 1:
            notify("ff5555", f"  Ungültig: Wert muss mindestens 1 sein")
            return
        config["max_windows"] = n
        save_config(config)
        trim_history(n)
        trim_hidden(n)
        notify("50fa7b", f"  Max. Fenster: {n}")
    except ValueError:
        notify("ff5555", f"  Ungültig: '{raw}' ist keine Zahl")


def menu_exclusions(config):
    excluded = config.get("excluded_classes", [])

    action = pick([
        "  App-ID manuell eingeben",
        "  Aus offenen Fenstern wählen",
        f"  Eintrag entfernen  ({len(excluded)} in Liste)" if excluded else "  Eintrag entfernen  (Liste leer)",
    ], "Ausschlussliste verwalten")
    if not action: return

    if "manuell" in action:
        # Freeform: user types any class/ID
        app_id = input_text("App-Klasse eingeben  (z.B. Alacritty, code, spotify)")
        if not app_id: return
        if app_id in excluded:
            notify("ff9900", f"  '{app_id}' ist bereits ausgeschlossen")
            return
        excluded.append(app_id)
        config["excluded_classes"] = excluded
        save_config(config)
        notify("ffb86c", f"  Ausgeschlossen: {app_id}")

    elif "offenen" in action:
        # Pick from currently open window classes
        try:
            r = subprocess.run(["hyprctl", "clients", "-j"], capture_output=True, text=True)
            clients = json.loads(r.stdout)
            classes = sorted(set(
                c["class"] for c in clients
                if c.get("class") and c["class"] not in excluded
            ))
        except:
            classes = []
        if not classes:
            notify("ff9900", "  Keine neuen Apps offen")
            return
        selected = pick(classes, "App ausschließen")
        if not selected: return
        excluded.append(selected)
        config["excluded_classes"] = excluded
        save_config(config)
        notify("ffb86c", f"  Ausgeschlossen: {selected}")

    elif "entfernen" in action:
        if not excluded:
            notify("ff9900", "  Ausschlussliste ist leer")
            return
        selected = pick(excluded, "Ausschluss aufheben")
        if not selected: return
        excluded.remove(selected)
        config["excluded_classes"] = excluded
        save_config(config)
        notify("50fa7b", f"  Wieder eingeschlossen: {selected}")


def main():
    mode   = get_mode()
    config = get_config()
    max_w  = config.get("max_windows", 5)
    excl   = config.get("excluded_classes", [])

    mode_label = "Hide" if mode == "hide" else "Relaunch"
    mode_icon  = "󰈉" if mode == "hide" else "󰑓"
    excl_label = ", ".join(excl[:3]) + ("…" if len(excl) > 3 else "") if excl else "keine"

    menu = [
        f"{mode_icon}  Modus: {mode_label}  →  wechseln",
        f"  Max. Fenster: {max_w}  →  Zahl eingeben",
        f"  Ausschlussliste: {excl_label}  →  verwalten",
    ]

    selected = pick(menu, "Window Restore Einstellungen")
    if not selected: return

    if "Modus" in selected:
        menu_mode(mode)
    elif "Max" in selected:
        menu_max(config)
    elif "Ausschluss" in selected:
        menu_exclusions(config)


if __name__ == "__main__":
    main()
