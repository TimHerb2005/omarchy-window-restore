#!/usr/bin/env python3
# hypr-close-window
# Saves the active window to history, then closes it.
# Called instead of killactive for SUPER+W.

import json
import os
import re
import shlex
import subprocess

HISTORY_FILE = os.path.expanduser("~/.cache/hypr-window-history.json")
MAX_HISTORY = 5


def get_launch_args(window_class: str, pid: int) -> list[str] | None:
    """
    Determine the correct launch args for this window.
    For Chromium-based apps all windows share one PID, so we use the
    window class to reconstruct the right command instead of reading cmdline.
    """
    # PWA launched via --app= : class is like "chrome-teams.cloud.microsoft__-Default"
    pwa_match = re.match(r"^chrome-([^_]+)__.*-Default$", window_class)
    if pwa_match:
        # Reconstruct URL from class: dots are dots, __ separates host from path
        host_part = pwa_match.group(1)  # e.g. "teams.cloud.microsoft"
        url = f"https://{host_part}/"
        # Use omarchy-launch-webapp to respect default browser setting
        return ["omarchy-launch-webapp", url]

    # Regular Chromium/Chrome window
    if window_class in ("chromium", "google-chrome", "brave-browser", "microsoft-edge"):
        return ["omarchy-launch-browser"]

    # For all other apps: read cmdline from /proc
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as f:
            raw = f.read()
        parts = [p.decode("utf-8", errors="replace") for p in raw.split(b"\x00") if p]
        if not parts:
            return None
        # Some apps pack everything into one space-separated string
        if len(parts) == 1 and " " in parts[0]:
            parts = shlex.split(parts[0])
        # Skip child processes (renderer, gpu, etc.)
        if "--type=" in " ".join(parts):
            return None
        return parts
    except Exception:
        return None


def load_history() -> list[dict]:
    try:
        with open(HISTORY_FILE) as f:
            return json.load(f)
    except Exception:
        return []


def save_to_history(window_class: str, args: list[str]) -> None:
    history = load_history()
    history.insert(0, {"class": window_class, "args": args})
    history = history[:MAX_HISTORY]
    os.makedirs(os.path.dirname(HISTORY_FILE), exist_ok=True)
    with open(HISTORY_FILE, "w") as f:
        json.dump(history, f)


def main() -> None:
    # Get active window
    result = subprocess.run(
        ["hyprctl", "activewindow", "-j"],
        capture_output=True, text=True, timeout=2
    )
    window = json.loads(result.stdout)
    pid = window.get("pid", 0)
    window_class = window.get("class", "")

    if window_class and pid > 0:
        args = get_launch_args(window_class, pid)
        if args:
            save_to_history(window_class, args)

    # Close the window
    subprocess.run(["hyprctl", "dispatch", "killactive"])


if __name__ == "__main__":
    main()

