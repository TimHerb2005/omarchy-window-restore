#!/usr/bin/env python3
# hypr-close-window: SUPER+W handler
# relaunch mode: saves launch args to history, then kills window
# hide mode:     moves window silently to hide workspace (process + state preserved)

import json, os, re, shlex, subprocess

HISTORY_FILE = os.path.expanduser("~/.cache/hypr-window-history.json")
HIDDEN_FILE  = os.path.expanduser("~/.cache/hypr-restore-hidden.json")
MODE_FILE    = os.path.expanduser("~/.cache/hypr-restore-mode")
CONFIG_FILE  = os.path.expanduser("~/.cache/hypr-restore-config.json")


def get_mode():
    try:
        with open(MODE_FILE) as f: return f.read().strip()
    except: return "relaunch"


def get_config():
    try:
        with open(CONFIG_FILE) as f: return json.load(f)
    except: return {"max_windows": 5, "excluded_classes": [], "hide_workspace": 99}


def load_json(path):
    try:
        with open(path) as f: return json.load(f)
    except: return []


def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f: json.dump(data, f)


def get_hide_ws_addresses(hide_ws):
    """Return set of window addresses currently on the hide workspace."""
    try:
        r = subprocess.run(["hyprctl", "clients", "-j"], capture_output=True, text=True)
        clients = json.loads(r.stdout)
        return {c["address"] for c in clients if c.get("workspace", {}).get("id") == hide_ws}
    except:
        return set()


def sync_hidden(hide_ws):
    """Sync HIDDEN_FILE with actual hide workspace contents.
    - Kills orphan windows (in hide WS but not tracked)
    - Removes stale entries (tracked but no longer in hide WS)
    Returns the cleaned hidden list."""
    hidden = load_json(HIDDEN_FILE)
    ws_addrs = get_hide_ws_addresses(hide_ws)
    tracked = {h["address"] for h in hidden}
    for addr in ws_addrs - tracked:
        subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{addr}"],
                       capture_output=True)
    cleaned = [h for h in hidden if h["address"] in ws_addrs]
    if len(cleaned) != len(hidden):
        save_json(HIDDEN_FILE, cleaned)
    return cleaned


def get_launch_args(window_class, pid):
    pwa = re.match(r"^chrome-([^_]+)__.*-Default$", window_class)
    if pwa:
        return ["omarchy-launch-webapp", f"https://{pwa.group(1)}/"]
    if window_class in ("chromium", "google-chrome", "brave-browser", "microsoft-edge"):
        return ["omarchy-launch-browser"]
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as f: raw = f.read()
        parts = [p.decode("utf-8", errors="replace") for p in raw.split(b"\x00") if p]
        if len(parts) == 1 and " " in parts[0]: parts = shlex.split(parts[0])
        if "--type=" in " ".join(parts): return None
        return parts or None
    except: return None


def mode_relaunch(window_class, pid, max_windows):
    args = get_launch_args(window_class, pid)
    if args:
        h = load_json(HISTORY_FILE)
        h.insert(0, {"class": window_class, "args": args})
        save_json(HISTORY_FILE, h[:max_windows])
    subprocess.run(["hyprctl", "dispatch", "killactive"])


def pause_media(window_class):
    """Pause all media players associated with this window class."""
    try:
        result = subprocess.run(["playerctl", "-l"], capture_output=True, text=True)
        players = [p for p in result.stdout.strip().split("\n") if p]
        matched = [p for p in players if p.lower().startswith(window_class.lower())]
        if matched:
            subprocess.run(["playerctl", "-p", ",".join(matched), "pause"], capture_output=True)
    except Exception:
        pass


def mode_hide(address, window_class, max_windows, pause_on_close, hide_ws):
    hidden = sync_hidden(hide_ws)
    if len(hidden) >= max_windows:
        oldest = hidden.pop()
        subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{oldest['address']}"],
                       capture_output=True)
    hidden.insert(0, {"address": address, "class": window_class})
    save_json(HIDDEN_FILE, hidden)
    if pause_on_close:
        pause_media(window_class)
    subprocess.run(["hyprctl", "dispatch", "movetoworkspacesilent", str(hide_ws)])


def main():
    try:
        r = subprocess.run(["hyprctl", "activewindow", "-j"], capture_output=True, text=True, timeout=3)
        w = json.loads(r.stdout)
    except Exception:
        return
    pid, window_class, address = w.get("pid", 0), w.get("class", ""), w.get("address", "")
    if not window_class:
        return

    config         = get_config()
    max_windows    = config.get("max_windows", 5)
    excluded       = config.get("excluded_classes", [])
    pause_on_close = config.get("pause_on_close", True)
    hide_ws        = config.get("hide_workspace", 99)

    if window_class in excluded:
        if pause_on_close:
            pause_media(window_class)
        subprocess.run(["hyprctl", "dispatch", "killactive"])
        return

    if get_mode() == "hide":
        if window_class and address:
            mode_hide(address, window_class, max_windows, pause_on_close, hide_ws)
    else:
        if window_class and pid > 0:
            mode_relaunch(window_class, pid, max_windows)


if __name__ == "__main__":
    main()



def get_mode():
    try:
        with open(MODE_FILE) as f: return f.read().strip()
    except: return "relaunch"


def get_config():
    try:
        with open(CONFIG_FILE) as f: return json.load(f)
    except: return {"max_windows": 5, "excluded_classes": [], "hide_workspace": 99}


def load_json(path):
    try:
        with open(path) as f: return json.load(f)
    except: return []


def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f: json.dump(data, f)


def get_ws99_addresses():
    """Return set of window addresses currently on workspace 99."""
    try:
        r = subprocess.run(["hyprctl", "clients", "-j"], capture_output=True, text=True)
        clients = json.loads(r.stdout)
        return {c["address"] for c in clients if c.get("workspace", {}).get("id") == HIDE_WS}
    except:
        return set()


def sync_hidden():
    """Sync HIDDEN_FILE with actual WS 99 contents.
    - Removes entries whose windows are no longer on WS 99
    - Kills WS 99 windows that are not tracked (orphans)
    Returns the cleaned hidden list."""
    hidden = load_json(HIDDEN_FILE)
    ws99 = get_ws99_addresses()
    tracked = {h["address"] for h in hidden}

    # Kill orphans: in WS 99 but not in hidden list
    for addr in ws99 - tracked:
        subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{addr}"],
                       capture_output=True)

    # Remove stale entries: in hidden list but not in WS 99
    cleaned = [h for h in hidden if h["address"] in ws99]
    if len(cleaned) != len(hidden):
        save_json(HIDDEN_FILE, cleaned)
    return cleaned


def get_launch_args(window_class, pid):
    pwa = re.match(r"^chrome-([^_]+)__.*-Default$", window_class)
    if pwa:
        return ["omarchy-launch-webapp", f"https://{pwa.group(1)}/"]
    if window_class in ("chromium", "google-chrome", "brave-browser", "microsoft-edge"):
        return ["omarchy-launch-browser"]
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as f: raw = f.read()
        parts = [p.decode("utf-8", errors="replace") for p in raw.split(b"\x00") if p]
        if len(parts) == 1 and " " in parts[0]: parts = shlex.split(parts[0])
        if "--type=" in " ".join(parts): return None
        return parts or None
    except: return None


def mode_relaunch(window_class, pid, max_windows):
    args = get_launch_args(window_class, pid)
    if args:
        h = load_json(HISTORY_FILE)
        h.insert(0, {"class": window_class, "args": args})
        save_json(HISTORY_FILE, h[:max_windows])
    subprocess.run(["hyprctl", "dispatch", "killactive"])


def pause_media(window_class):
    """Pause all media players associated with this window class."""
    try:
        result = subprocess.run(["playerctl", "-l"], capture_output=True, text=True)
        players = [p for p in result.stdout.strip().split("\n") if p]
        # Match ALL instances of this player (e.g. chromium.instance1, chromium.instance2)
        matched = [p for p in players if p.lower().startswith(window_class.lower())]
        if matched:
            subprocess.run(
                ["playerctl", "-p", ",".join(matched), "pause"],
                capture_output=True
            )
    except Exception:
        pass


def mode_hide(address, window_class, max_windows, pause_on_close=True):
    hidden = sync_hidden()  # sync with actual WS 99 state first
    if len(hidden) >= max_windows:
        oldest = hidden.pop()
        subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{oldest['address']}"],
                       capture_output=True)
    hidden.insert(0, {"address": address, "class": window_class})
    save_json(HIDDEN_FILE, hidden)
    # Pause any media playing in this window before hiding
    if pause_on_close:
        pause_media(window_class)
    # Move silently to high workspace — process keeps running, UI disappears
    subprocess.run(["hyprctl", "dispatch", "movetoworkspacesilent", str(HIDE_WS)])


def main():
    try:
        r = subprocess.run(["hyprctl", "activewindow", "-j"], capture_output=True, text=True, timeout=3)
        w = json.loads(r.stdout)
    except Exception:
        return  # No active window or hyprctl unavailable
    pid, window_class, address = w.get("pid", 0), w.get("class", ""), w.get("address", "")
    if not window_class:
        return  # Nothing focused (e.g. empty desktop)

    config      = get_config()
    max_windows = config.get("max_windows", 5)
    excluded    = config.get("excluded_classes", [])
    pause_on_close = config.get("pause_on_close", True)
    hide_ws     = config.get("hide_workspace", 99)

    # If class is excluded: pause media (if enabled) then kill directly, never track or hide
    if window_class in excluded:
        if pause_on_close:
            pause_media(window_class)
        subprocess.run(["hyprctl", "dispatch", "killactive"])
        return

    if get_mode() == "hide":
        if window_class and address:
            mode_hide(address, window_class, max_windows, pause_on_close, hide_ws)
    else:
        if window_class and pid > 0:
            mode_relaunch(window_class, pid, max_windows)


if __name__ == "__main__":
    main()
