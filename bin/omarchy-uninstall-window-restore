#!/bin/bash
# omarchy-uninstall-window-restore
# Removes Window Restore from the current user.
# Run this before: sudo pacman -R omarchy-window-restore-git

set -e

BIN_DIR="$HOME/.local/bin"
BINDINGS_FILE="$HOME/.config/hypr/bindings.conf"
HOOK_FILE="/etc/pacman.d/hooks/omarchy-window-restore-remove.hook"

echo "Deactivating Omarchy Window Restore..."

# Remove scripts
for script in hypr-close-window hypr-restore-window hypr-restore-all hypr-restore-picker hypr-restore-settings; do
  rm -f "$BIN_DIR/$script"
done
echo "  ✓ Scripts removed"

# Remove keybindings block
if grep -q "# Window Restore" "$BINDINGS_FILE" 2>/dev/null; then
  python3 - "$BINDINGS_FILE" << 'EOF'
import sys

path = sys.argv[1]
with open(path) as f:
    lines = f.readlines()

out = []
skip = False
i = 0
while i < len(lines):
    line = lines[i]
    if "# Window Restore" in line:
        skip = True
    if skip and line.strip() == "" and i > 0 and "# Window Restore" not in lines[i-1]:
        skip = False
    if not skip:
        out.append(line)
    i += 1

with open(path, "w") as f:
    f.writelines(out)
EOF
  echo "  ✓ Keybindings removed from $BINDINGS_FILE"
  echo "  ℹ  SUPER+W is restored to default (killactive) behavior"
fi

# Remove pacman hook
if [ -f "$HOOK_FILE" ]; then
  sudo rm -f "$HOOK_FILE"
  echo "  ✓ Pacman hook removed"
fi

# Clean up cache files
rm -f "$HOME/.cache/hypr-window-history.json"
rm -f "$HOME/.cache/hypr-window-history.log"
rm -f "$HOME/.cache/hypr-restore-hidden.json"
rm -f "$HOME/.cache/hypr-restore-mode"
rm -f "$HOME/.cache/hypr-restore-config.json"
echo "  ✓ Cache cleared"

echo ""
echo "Done! Window Restore has been fully removed for your user."
echo "You can now safely run: sudo pacman -R omarchy-window-restore-git"
