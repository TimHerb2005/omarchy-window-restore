#!/usr/bin/env python3
# hypr-restore-picker: SUPER+ALT+R – walker menu to pick window

import json, os, subprocess

HISTORY_FILE = os.path.expanduser("~/.cache/hypr-window-history.json")
HIDDEN_FILE  = os.path.expanduser("~/.cache/hypr-restore-hidden.json")
MODE_FILE    = os.path.expanduser("~/.cache/hypr-restore-mode")


def notify(color, msg):
    subprocess.run(["notify-send", "-t", "3000", "Window Restore", msg])

def get_mode():
    try:
        with open(MODE_FILE) as f: return f.read().strip()
    except: return "relaunch"

def load_json(path):
    try:
        with open(path) as f: return json.load(f)
    except: return []

def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f: json.dump(data, f)

def launch(args):
    if args[0].startswith("omarchy-"):
        subprocess.Popen(args)
    else:
        subprocess.Popen(["uwsm-app", "--"] + args)

def show_picker(entries, label_fn):
    labels = [f"{i+1}. {label_fn(e)}" for i, e in enumerate(entries)]
    result = subprocess.run(
        ["walker", "--dmenu", "--placeholder", "Restore window"],
        input="\n".join(labels), capture_output=True, text=True
    )
    selected = result.stdout.strip()
    if not selected:
        return None
    try:
        return int(selected.split(".")[0]) - 1
    except (ValueError, IndexError):
        return None


def main():
    if get_mode() == "hide":
        hidden = load_json(HIDDEN_FILE)
        if not hidden:
            notify("ff9900", " No hidden windows")
            return
        idx = show_picker(hidden, lambda e: e.get("class", "?"))
        if idx is None:
            return
        entry = hidden.pop(idx)
        save_json(HIDDEN_FILE, hidden)
        addr = entry.get("address", "")
        if addr:
            subprocess.run(["hyprctl", "dispatch", "movetoworkspace", f"e+0,address:{addr}"])
            notify("50fa7b", f" Restored: {entry.get('class', 'app')}")
    else:
        history = load_json(HISTORY_FILE)
        if not history:
            notify("ff9900", " No windows in history")
            return
        def label(e):
            args = e.get("args", [])
            app_url = next((a for a in args if a.startswith("--app=")), None)
            if app_url:
                return app_url.removeprefix("--app=https://").split("/")[0]
            return e.get("class", "?")
        idx = show_picker(history, label)
        if idx is None:
            return
        entry = history.pop(idx)
        save_json(HISTORY_FILE, history)
        args = entry.get("args", [])
        if args:
            launch(args)
            notify("50fa7b", f" Restored: {entry.get('class', 'app')}")


if __name__ == "__main__":
    main()
