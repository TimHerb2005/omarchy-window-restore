#!/usr/bin/env python3
# hypr-restore-all: SUPER+SHIFT+R – restore all windows at once

import json, os, subprocess

HISTORY_FILE = os.path.expanduser("~/.cache/hypr-window-history.json")
HIDDEN_FILE  = os.path.expanduser("~/.cache/hypr-restore-hidden.json")
MODE_FILE    = os.path.expanduser("~/.cache/hypr-restore-mode")
CONFIG_FILE  = os.path.expanduser("~/.cache/hypr-restore-config.json")
HIDE_WS      = 99


def get_config():
    try:
        with open(CONFIG_FILE) as f: return json.load(f)
    except: return {}


def notify(color, msg):
    cfg = get_config()
    if not cfg.get("notifications_enabled", True):
        return
    subprocess.run(["notify-send", "-t", "3000", "Window Restore", msg])

def get_mode():
    try:
        with open(MODE_FILE) as f: return f.read().strip()
    except: return "relaunch"

def load_json(path):
    try:
        with open(path) as f: return json.load(f)
    except: return []

def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f: json.dump(data, f)

def launch(args):
    if args[0].startswith("omarchy-"):
        subprocess.Popen(args)
    else:
        subprocess.Popen(["uwsm-app", "--"] + args)


def get_ws99_addresses():
    try:
        r = subprocess.run(["hyprctl", "clients", "-j"], capture_output=True, text=True)
        clients = json.loads(r.stdout)
        return {c["address"] for c in clients if c.get("workspace", {}).get("id") == HIDE_WS}
    except:
        return set()


def sync_hidden():
    """Remove stale entries and kill orphan WS 99 windows."""
    hidden = load_json(HIDDEN_FILE)
    ws99 = get_ws99_addresses()
    tracked = {h["address"] for h in hidden}
    for addr in ws99 - tracked:
        subprocess.run(["hyprctl", "dispatch", "closewindow", f"address:{addr}"],
                       capture_output=True)
    cleaned = [h for h in hidden if h["address"] in ws99]
    if len(cleaned) != len(hidden):
        save_json(HIDDEN_FILE, cleaned)
    return cleaned


def main():
    if get_mode() == "hide":
        hidden = sync_hidden()
        if not hidden:
            notify("ff9900", " No hidden windows")
            return
        for entry in hidden:
            addr = entry.get("address", "")
            if addr:
                subprocess.run(["hyprctl", "dispatch", "movetoworkspace", f"e+0,address:{addr}"])
        save_json(HIDDEN_FILE, [])
        notify("50fa7b", f" {len(hidden)} window{'s' if len(hidden) != 1 else ''} restored")
    else:
        history = load_json(HISTORY_FILE)
        if not history:
            notify("ff9900", " No windows in history")
            return
        for entry in history:
            args = entry.get("args", [])
            if args:
                launch(args)
        save_json(HISTORY_FILE, [])
        notify("50fa7b", f" {len(history)} window{'s' if len(history) != 1 else ''} restored")


if __name__ == "__main__":
    main()
