#!/usr/bin/env python3
# hypr-restore-all: SUPER+SHIFT+R – restore all windows at once

import json, os, subprocess

HISTORY_FILE = os.path.expanduser("~/.cache/hypr-window-history.json")
HIDDEN_FILE  = os.path.expanduser("~/.cache/hypr-restore-hidden.json")
MODE_FILE    = os.path.expanduser("~/.cache/hypr-restore-mode")


def notify(color, msg):
    subprocess.run(["hyprctl", "notify", "0", "3000", f"rgb({color})", msg])

def get_mode():
    try:
        with open(MODE_FILE) as f: return f.read().strip()
    except: return "relaunch"

def load_json(path):
    try:
        with open(path) as f: return json.load(f)
    except: return []

def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f: json.dump(data, f)

def launch(args):
    if args[0].startswith("omarchy-"):
        subprocess.Popen(args)
    else:
        subprocess.Popen(["uwsm-app", "--"] + args)


def main():
    if get_mode() == "hide":
        hidden = load_json(HIDDEN_FILE)
        if not hidden:
            notify("ff9900", " No hidden windows")
            return
        for entry in hidden:
            addr = entry.get("address", "")
            if addr:
                subprocess.run(["hyprctl", "dispatch", "movetoworkspace", f"e+0,address:{addr}"])
        save_json(HIDDEN_FILE, [])
        notify("50fa7b", f" {len(hidden)} window{'s' if len(hidden) != 1 else ''} restored")
    else:
        history = load_json(HISTORY_FILE)
        if not history:
            notify("ff9900", " No windows in history")
            return
        for entry in history:
            args = entry.get("args", [])
            if args:
                launch(args)
        save_json(HISTORY_FILE, [])
        notify("50fa7b", f" {len(history)} window{'s' if len(history) != 1 else ''} restored")


if __name__ == "__main__":
    main()
